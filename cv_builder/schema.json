{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/giocaizzi/CV/cv-schema.json",
  "title": "CV Schema",
  "description": "JSON schema for CV data (JSON Resume-aligned)",
  "type": "object",
  "required": ["basics", "work", "education", "certificates", "technicalSkills", "projects", "personalSkills"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "basics": {
      "type": "object",
      "description": "Basic personal and contact information",
      "required": ["name", "email", "location", "profiles"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "location": {
          "type": "object",
          "description": "Current location (JSON Resume canonical object shape)",
          "additionalProperties": true,
          "properties": {
            "address": {
              "type": "string",
              "description": "Street address"
            },
            "postalCode": {
              "type": "string",
              "description": "Postal code"
            },
            "city": {
              "type": "string",
              "description": "City"
            },
            "countryCode": {
              "type": "string",
              "description": "ISO 3166-1 alpha-2 country code"
            },
            "region": {
              "type": "string",
              "description": "Region or state"
            }
          }
        },
        "profiles": {
          "type": "array",
          "description": "Social/professional network profiles",
          "items": {
            "type": "object",
            "required": ["network", "url", "x-inResume"],
            "additionalProperties": false,
            "properties": {
              "network": {
                "type": "string",
                "description": "Network name (e.g. LinkedIn, GitHub, Website)"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "Profile URL"
              },
              "x-inResume": {
                "type": "boolean",
                "description": "Whether to show in resume"
              }
            }
          }
        }
      }
    },
    "work": {
      "type": "array",
      "description": "Work experience entries",
      "items": {
        "type": "object",
        "required": ["position", "name", "location", "startDate", "summary", "highlights", "x-inResume"],
        "additionalProperties": false,
        "properties": {
          "position": {
            "type": "string",
            "description": "Job title / position"
          },
          "name": {
            "type": "string",
            "description": "Company name"
          },
          "location": {
            "type": "string",
            "description": "Work location"
          },
          "startDate": {
            "type": "string",
            "description": "Start date (ISO 8601: YYYY-MM)"
          },
          "endDate": {
            "type": ["string", "null"],
            "description": "End date (ISO 8601: YYYY-MM, or null if current)"
          },
          "summary": {
            "type": "string",
            "description": "Short job description (used in resume)"
          },
          "x-longSummary": {
            "type": "string",
            "description": "Full detailed job description (not shown in resume)"
          },
          "highlights": {
            "type": "array",
            "description": "List of highlights/responsibilities",
            "items": {
              "type": "object",
              "required": ["value", "x-inResume"],
              "additionalProperties": false,
              "properties": {
                "value": {
                  "type": "string",
                  "description": "Highlight description"
                },
                "x-inResume": {
                  "type": "boolean",
                  "description": "Whether this highlight appears in the resume"
                }
              }
            }
          },
          "x-projects": {
            "type": "array",
            "description": "Detailed projects worked on during this position",
            "items": {
              "type": "object",
              "required": ["name", "description"],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Project name"
                },
                "description": {
                  "type": "string",
                  "description": "Detailed project description"
                },
                "x-technologies": {
                  "type": "string",
                  "description": "Technologies used in the project (comma-separated)"
                },
                "achievements": {
                  "type": "array",
                  "description": "Key achievements or outcomes from the project",
                  "items": {
                    "type": "string"
                  }
                },
                "url": {
                  "type": "string",
                  "format": "uri",
                  "description": "Project URL if publicly available"
                },
                "client": {
                  "type": "string",
                  "description": "Client name (if applicable)"
                },
                "x-inResume": {
                  "type": "boolean",
                  "description": "Whether this project appears in the resume"
                }
              }
            }
          },
          "x-inResume": {
            "type": "boolean",
            "description": "Whether this work entry appears in the resume"
          }
        }
      }
    },
    "education": {
      "type": "array",
      "description": "Education entries",
      "items": {
        "type": "object",
        "required": ["area", "institution", "location", "startDate", "endDate", "x-details", "x-inResume"],
        "additionalProperties": false,
        "properties": {
          "area": {
            "type": "string",
            "description": "Field of study / degree name"
          },
          "institution": {
            "type": "string",
            "description": "Educational institution name"
          },
          "location": {
            "type": "string",
            "description": "Institution location"
          },
          "startDate": {
            "type": "string",
            "description": "Start date (ISO 8601: YYYY-MM)"
          },
          "endDate": {
            "type": "string",
            "description": "End date (ISO 8601: YYYY-MM)"
          },
          "x-details": {
            "type": "object",
            "description": "Additional details about the education (e.g. msc, bsc sub-objects)",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "courses": {
                  "type": "string",
                  "description": "Relevant courses"
                },
                "thesis": {
                  "type": "string",
                  "description": "Thesis title"
                }
              }
            }
          },
          "x-inResume": {
            "type": "boolean",
            "description": "Whether this education entry appears in the resume"
          }
        }
      }
    },
    "certificates": {
      "type": "array",
      "description": "Professional licenses and certifications",
      "items": {
        "type": "object",
        "required": ["name", "date", "x-inResume"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "License or certification name"
          },
          "date": {
            "type": "string",
            "description": "Year obtained (ISO year-only: YYYY)"
          },
          "x-inResume": {
            "type": "boolean",
            "description": "Whether this certificate appears in the resume"
          }
        }
      }
    },
    "technicalSkills": {
      "type": "object",
      "description": "Technical skills organized by category",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "x-inResume"],
        "additionalProperties": false,
        "properties": {
          "value": {
            "type": "string",
            "description": "Comma-separated list of skills in this category"
          },
          "x-inResume": {
            "type": "boolean",
            "description": "Whether this skill category appears in the resume"
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "description": "Personal or professional projects",
      "items": {
        "type": "object",
        "required": ["name", "url", "description", "x-technologies", "x-inResume"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Project name"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Project URL (typically GitHub repository)"
          },
          "description": {
            "type": "string",
            "description": "Short project description"
          },
          "x-technologies": {
            "type": "string",
            "description": "Technologies used (comma-separated)"
          },
          "x-inResume": {
            "type": "boolean",
            "description": "Whether this project appears in the resume"
          }
        }
      }
    },
    "personalSkills": {
      "type": "object",
      "description": "Personal skills like languages and interests",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "x-inResume"],
        "additionalProperties": false,
        "properties": {
          "value": {
            "type": "string",
            "description": "Description of the personal skill"
          },
          "x-inResume": {
            "type": "boolean",
            "description": "Whether this personal skill appears in the resume"
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "Metadata about the CV document",
      "additionalProperties": false,
      "properties": {
        "footer": {
          "type": "object",
          "description": "Footer text for the CV",
          "required": ["value", "x-inResume"],
          "additionalProperties": false,
          "properties": {
            "value": {
              "type": "string",
              "description": "Footer text content"
            },
            "x-inResume": {
              "type": "boolean",
              "description": "Whether to show footer in resume"
            }
          }
        }
      }
    }
  }
}
